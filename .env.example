# ========================================================
# .env.example — このファイルをコピーして .env を作成する
# .env は絶対に Git にコミットしない（.gitignore で除外済み）
# ========================================================

# デプロイ用ウォレットの秘密鍵（0x から始まる64文字）
# 注意: テスト専用アカウントを使うこと。資産を持つメインアカウントは使わない
PRIVATE_KEY=0xここに秘密鍵を貼る

# Polygon Amoy テストネットの RPC URL
# Alchemy の場合: https://polygon-amoy.g.alchemy.com/v2/あなたのAPIキー
# または無料パブリックRPC: https://rpc-amoy.polygon.technology
POLYGON_AMOY_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/ここにAPIキーを貼る

# Polygonscan API キー（コントラクトのソースコード公開に使用・任意）
# https://polygonscan.com/myapikey で取得
POLYGONSCAN_API_KEY=ここにAPIキーを貼る
